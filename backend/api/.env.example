# =============================================
# ARCHIVO DE EJEMPLO - COPIAR A .env EN PRODUCCIÓN
# =============================================
# NO SUBIR ESTE ARCHIVO CON CREDENCIALES REALES
# Úsalo como referencia para configurar variables en Render

# =============================================
# Spring Profiles (dev/prod)
# =============================================
SPRING_PROFILES_ACTIVE=dev

# =============================================
# Base de datos PostgreSQL (Neon)
# =============================================
SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/database?sslmode=require
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password

# =============================================
# JWT - Autenticación
# =============================================
JWT_SECRET=your-secret-key-min-32-characters-long-change-this
JWT_EXPIRATION_MINUTES=1440

# =============================================
# Cloudflare R2 - Almacenamiento de imágenes
# =============================================
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_BASE_URL=https://your-domain.com

# =============================================
# CORS - Dominios permitidos
# =============================================
CORS_ALLOWED_ORIGINS=https://www.galeriafutbol.com,https://admin.galeriafutbol.com
